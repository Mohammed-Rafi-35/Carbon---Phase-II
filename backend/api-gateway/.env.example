APP_NAME=API Gateway
APP_ENV=development
ENFORCE_HTTPS=false
ANALYTICS_SERVICE_URL=http://analytics-service:8000
IDENTITY_SERVICE_URL=http://identity-service:8000
CLAIMS_SERVICE_URL=http://claims-service:8000
POLICY_SERVICE_URL=http://policy-pricing-service:8000
FRAUD_SERVICE_URL=http://fraud-service:8000
PAYOUT_SERVICE_URL=http://payout-service:8000
AI_SERVICE_URL=http://ai-risk-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000
TRIGGER_SERVICE_URL=http://trigger-service:8000

REQUEST_TIMEOUT_SECONDS=3
UPSTREAM_RETRY_ATTEMPTS=2
UPSTREAM_RETRY_BACKOFF_SECONDS=0.1
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_OPEN_SECONDS=30

JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

RATE_LIMIT_PER_MINUTE=60
MAX_REQUEST_BODY_BYTES=1048576
CORS_ALLOW_ORIGINS_CSV=http://localhost:3000
AUTH_EXEMPT_PATHS_CSV=/health,/docs,/redoc,/openapi.json,/api/v1/auth