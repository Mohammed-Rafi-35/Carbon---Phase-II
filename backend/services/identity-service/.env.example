APP_NAME=Identity & Worker Service
APP_ENV=development
DEBUG=false
API_V1_PREFIX=/api/v1
ENFORCE_HTTPS=false
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/identity_db
DATABASE_CONNECT_TIMEOUT_SECONDS=5
ENABLE_DEV_SQLITE_FALLBACK=true
DEV_SQLITE_FALLBACK_URL=sqlite:///./identity_dev.db
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRY=3600
REDIS_URL=redis://localhost:6379/0
INTEGRATION_TIMEOUT_SECONDS=5
POLICY_SERVICE_URL=http://policy-pricing-service:8001
CLAIMS_SERVICE_URL=http://claims-service:8002
AUTO_CREATE_TABLES=false
