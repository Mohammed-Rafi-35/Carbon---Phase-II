APP_NAME=Notification Service
APP_ENV=development
DEBUG=false
API_V1_PREFIX=/api/v1
ENFORCE_HTTPS=false

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5438/notification_db
DATABASE_CONNECT_TIMEOUT_SECONDS=5
AUTO_CREATE_TABLES=false

RABBITMQ_URL=amqp://guest:guest@localhost:5672//
REDIS_URL=redis://localhost:6379/0
ENABLE_EVENT_BUS_CONSUMER=true
NOTIFICATION_EVENT_QUEUE_NAME=notification.events
NOTIFICATION_EVENT_ROUTING_KEY=#
RETRY_LIMIT=3
PREFETCH_COUNT=10

SMS_API_KEY=
PUSH_API_KEY=
MAX_RETRIES=3

JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
RATE_LIMIT_PER_MINUTE=60
