APP_ENV=development
PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5437/fraud_db
RABBITMQ_URL=amqp://guest:guest@localhost:5672//
FRAUD_EXCHANGE_NAME=devtrails.events
FRAUD_INBOUND_QUEUE_NAME=fraud.claims
FRAUD_INBOUND_ROUTING_KEY=claim.initiated
FRAUD_DETECTED_ROUTING_KEY=fraud.detected
ENABLE_EVENT_CONSUMER=true
RETRY_LIMIT=3
PREFETCH_COUNT=10
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
RATE_LIMIT_PER_MINUTE=60
FRAUD_FAIL_THRESHOLD=0.70
MAX_DUPLICATE_CLAIMS=1
ENABLE_ML=false
MODEL_PATH=
INTEGRATION_TIMEOUT_SECONDS=5
IDENTITY_SERVICE_URL=http://identity-service:8000
AI_RISK_SERVICE_URL=http://ai-risk-service:8000
AUTO_CREATE_TABLES=false
RUN_MIGRATIONS=true
