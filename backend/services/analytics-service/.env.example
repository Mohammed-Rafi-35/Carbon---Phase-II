APP_NAME=Analytics Service
APP_ENV=development
DEBUG=false
API_V1_PREFIX=/api/v1
ENFORCE_HTTPS=false

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5440/analytics_db
DATABASE_CONNECT_TIMEOUT_SECONDS=5
AUTO_CREATE_TABLES=false

RABBITMQ_URL=amqp://guest:guest@localhost:5672//
REDIS_URL=redis://localhost:6379/0
ANALYTICS_EXCHANGE_NAME=devtrails.events
ANALYTICS_EVENT_QUEUE_NAME=analytics.events
ANALYTICS_EVENT_ROUTING_KEY=#
ENABLE_EVENT_CONSUMER=true
RETRY_LIMIT=3
PREFETCH_COUNT=10

JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
RATE_LIMIT_PER_MINUTE=120

CACHE_TTL_SECONDS=300
DASHBOARD_CACHE_TTL_SECONDS=60
ZONES_CACHE_TTL_SECONDS=120
TIMESERIES_CACHE_TTL_SECONDS=120
DEFAULT_LOOKBACK_DAYS=30
