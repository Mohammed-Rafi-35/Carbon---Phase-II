APP_ENV=development
PORT=8013
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5436/claims_db
RABBITMQ_URL=amqp://guest:guest@localhost:5672//
CLAIMS_EXCHANGE_NAME=devtrails.events
CLAIMS_INBOUND_QUEUE_NAME=claims.disruption
CLAIMS_PROCESSING_QUEUE_NAME=claims.processing
CLAIMS_INBOUND_ROUTING_KEY=trigger.disruption_detected
CLAIM_PROCESSING_ROUTING_KEY=claim.processing
CLAIM_INITIATED_ROUTING_KEY=claim.initiated
CLAIM_APPROVED_ROUTING_KEY=claim.approved
ENABLE_EVENT_CONSUMER=true
RETRY_LIMIT=3
PREFETCH_COUNT=10
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
RATE_LIMIT_PER_MINUTE=60
POLICY_SERVICE_URL=http://localhost:8004
AI_SERVICE_URL=http://localhost:8007
FRAUD_SERVICE_URL=http://localhost:8010
PAYOUT_SERVICE_URL=http://localhost:8011
RISK_REJECT_THRESHOLD=0.95
RISK_DEFAULT_ZONE=UNKNOWN
DEFAULT_CLAIM_USERS_CSV=16fd2706-8baf-433b-82eb-8c7fada847da
DEFAULT_PAYOUT_AMOUNT=500
AUTO_CREATE_TABLES=false
RUN_MIGRATIONS=false
