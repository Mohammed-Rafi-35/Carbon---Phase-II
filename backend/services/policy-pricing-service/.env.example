APP_NAME=Policy & Pricing Service
APP_ENV=development
DEBUG=false
API_V1_PREFIX=/api/v1
ENFORCE_HTTPS=false

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/policy_pricing_db
DATABASE_CONNECT_TIMEOUT_SECONDS=5

RABBITMQ_URL=amqp://guest:guest@localhost:5672//
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=dev-secret
JWT_ALGORITHM=HS256

GST_RATE=0.18
WAITING_PERIOD_HOURS=48
RATE_LIMIT_PER_MINUTE=60

INTEGRATION_TIMEOUT_SECONDS=5.0
IDENTITY_SERVICE_URL=http://localhost:8005
FRAUD_SERVICE_URL=http://localhost:8003
CLAIMS_SERVICE_URL=http://localhost:8002
AI_RISK_SERVICE_URL=http://localhost:8001

AUTO_CREATE_TABLES=false
