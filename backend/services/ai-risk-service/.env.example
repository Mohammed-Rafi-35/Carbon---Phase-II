APP_ENV=development
PORT=8000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5438/ai_risk_db
RUN_MIGRATIONS=true
MODEL_PATH=ml/models/risk_model_v1.pkl
MODEL_REGISTRY_PATH=ml/models/model_registry.json
METADATA_PATH=ml/models/metadata.json
ENABLE_EXTERNAL_SIGNALS=false
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
RATE_LIMIT_PER_MINUTE=120
