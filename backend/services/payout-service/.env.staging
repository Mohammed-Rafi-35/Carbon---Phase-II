APP_NAME=Payout Service
APP_ENV=staging
DEBUG=false
API_V1_PREFIX=/api/v1
ENFORCE_HTTPS=true

DATABASE_URL=postgresql+psycopg://postgres:postgres@payout-db:5432/payout_db
DATABASE_CONNECT_TIMEOUT_SECONDS=5
AUTO_CREATE_TABLES=false

JWT_SECRET=replace-in-staging
JWT_ALGORITHM=HS256
RATE_LIMIT_PER_MINUTE=100

PAYMENT_PROVIDER=mock
PAYMENT_GATEWAY_API_KEY=replace-in-staging
PAYMENT_GATEWAY_SECRET=replace-in-staging
PAYMENT_TIMEOUT_SECONDS=10
MOCK_GATEWAY_FORCE_FAILURE=false

MAX_RETRY=3

ENABLE_EVENT_PUBLISH=true
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
PAYOUT_COMPLETED_EVENT_ROUTING_KEY=payout.completed
PAYOUT_FAILED_EVENT_ROUTING_KEY=payout.failed
