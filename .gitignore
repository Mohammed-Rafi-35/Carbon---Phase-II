# ------------------------------------------------------------------------------
# CORE RULE: Track everything by default
# (Safer than ignoring everything and re-allowing)
# ------------------------------------------------------------------------------

# Explicitly ignore unwanted top-level directories
frontend/
Documentation/
docs/

# ------------------------------------------------------------------------------
# ENVIRONMENT & SECRETS (CRITICAL)
# ------------------------------------------------------------------------------

.env
.env.*
*.env
*.env.*

# Allow example env files
!.env.example
!**/.env.example

# Secrets and sensitive configs
secrets.*
*secret*
*SECRET*

# Keys / Certificates
*.pem
*.key
*.crt
*.p12
*.pfx
*id_rsa*
*id_dsa*

# Cloud credentials
.aws/
.azure/
.gcp/

# Terraform state
*.tfstate
*.tfstate.*

# ------------------------------------------------------------------------------
# PYTHON (BACKEND SERVICES)
# ------------------------------------------------------------------------------

__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.nox/
.tox/

# Coverage reports
.coverage
.coverage.*
htmlcov/
coverage/

# Build artifacts
build/
dist/
*.egg-info/
*.egg

# Pip metadata
pip-wheel-metadata/

# ------------------------------------------------------------------------------
# LOGS & RUNTIME FILES
# ------------------------------------------------------------------------------

*.log
*.out
*.err
*.pid
*.pid.lock

# ------------------------------------------------------------------------------
# NOTEBOOKS / DATA SCIENCE
# ------------------------------------------------------------------------------

.ipynb_checkpoints/
*.nbconvert.ipynb

# ------------------------------------------------------------------------------
# OS & EDITOR FILES
# ------------------------------------------------------------------------------

.DS_Store
Thumbs.db

.idea/
.vscode/

# ------------------------------------------------------------------------------
# DOCKER & INFRASTRUCTURE
# ------------------------------------------------------------------------------

docker-compose.override.yml

# Optional: Ignore local-only infra configs
infrastructure/.env

# ------------------------------------------------------------------------------
# LARGE FILES / ML MODELS
# ------------------------------------------------------------------------------

*.pt
*.pth
*.onnx
*.h5
*.ckpt
*.bin

# Data artifacts
*.parquet
*.feather
*.npy
*.npz

# Archives
*.zip
*.tar
*.tar.gz
*.7z

# ------------------------------------------------------------------------------
# TEST ARTIFACTS
# ------------------------------------------------------------------------------

.cache/
site/

# ------------------------------------------------------------------------------
# GIT SAFETY (IMPORTANT)
# ------------------------------------------------------------------------------

# Always track these
!.gitignore
!README.md
!docker-compose.yml
!requirements.txt

# ------------------------------------------------------------------------------
# PROJECT-SPECIFIC (CARBON ARCHITECTURE)
# ------------------------------------------------------------------------------

# Ensure backend services are tracked
!backend/
!backend/**

# If you later add:
!services/
!services/**

!api-gateway/
!api-gateway/**